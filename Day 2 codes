//1D Array using Create , Read , Update , Delete
import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String[] items = new String[10];
        int count = 0;
        while (true) {
            System.out.println("1. Create (Add Item)");
            System.out.println("2. Read (View All)");
            System.out.println("3. Update (Change Item)");
            System.out.println("4. Delete (Remove Item)");
            System.out.println("5. Exit");
            System.out.print("Select an option: ");
            int choice = sc.nextInt();
            sc.nextLine();
            switch (choice) {
                case 1:
                    if (count < items.length) {
                        System.out.print("Enter name to add: ");
                        items[count++] = sc.nextLine();
                        System.out.println("Added successfully!");
                    } else {
                        System.out.println("Array is full!");
                    }
                    break;
                case 2:
                    System.out.println("Current Items:");
                    for (int i = 0; i < count; i++) {
                        System.out.println(i + ": " + items[i]);
                    }
                    break;
                case 3:
                    System.out.print("Enter index to update: ");
                    int upIdx = sc.nextInt();
                    sc.nextLine();
                    if (upIdx >= 0 && upIdx < count) {
                        System.out.print("Enter new name: ");
                        items[upIdx] = sc.nextLine();
                        System.out.println("Updated!");
                    } else {
                        System.out.println("Invalid index!");
                    }
                    break;
                case 4:
                    System.out.print("Enter index to delete: ");
                    int delIdx = sc.nextInt();
                    if (delIdx >= 0 && delIdx < count) {
                        for (int i = delIdx; i < count - 1; i++) {
                            items[i] = items[i + 1];
                        }
                        items[--count] = null;
                        System.out.println("Deleted successfully!");
                    } else {
                        System.out.println("Invalid index!");
                    }
                    break;
                case 5:
                    System.out.println("Exiting...");
                    System.exit(0);
                default:
                    System.out.println("Invalid choice!");
            }
        }
    }
}
//2D Array using Create , Read , Update , Delete
import java.util.Scanner;
public class TwoDArrayCRUD {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int[][] data = new int[10][2]; 
        int rowCount = 0;
        while (true) {
            System.out.println("1. Create (Add Row)");
            System.out.println("2. Read (View All)");
            System.out.println("3. Update (Change Value)");
            System.out.println("4. Delete (Remove Row)");
            System.out.println("5. Exit");
            System.out.print("Select: ");
            int choice = sc.nextInt();
            switch (choice) {
                case 1:
                    if (rowCount < data.length) {
                        System.out.print("Enter Student ID: ");
                        data[rowCount][0] = sc.nextInt();
                        System.out.print("Enter Score: ");
                        data[rowCount][1] = sc.nextInt();
                        rowCount++;
                    } else {
                        System.out.println("Table is full!");
                    }
                    break;
                case 2:
                    System.out.println("ID\tScore");
                    for (int i = 0; i < rowCount; i++) {
                        System.out.println(data[i][0] + "\t" + data[i][1]);
                    }
                    break;
                case 3:
                    System.out.print("Enter row index to update (0-" + (rowCount-1) + "): ");
                    int upIdx = sc.nextInt();
                    if (upIdx >= 0 && upIdx < rowCount) {
                        System.out.print("Enter new Score: ");
                        data[upIdx][1] = sc.nextInt();
                        System.out.println("Updated!");
                    }
                    break;
                case 4:
                    System.out.print("Enter row index to delete: ");
                    int delIdx = sc.nextInt();
                    if (delIdx >= 0 && delIdx < rowCount) {
                        for (int i = delIdx; i < rowCount - 1; i++) {
                            data[i] = data[i + 1];
                        }
                        rowCount--;
                        System.out.println("Deleted!");
                    }
                    break;
                case 5:
                    System.exit(0);
            }
        }
    }
}
