class Main{
    public static void main(String[] args){
        int n = 10;
        int m = 4;
        try{
            int ans = n / m;
            System.out.println("Answer: " + ans);
        } catch (ArithmeticException e){
            System.out.println("Error:Division by 0!");
        }
    }
}
