//copy constructor
class Student {
    String name;
    int regNo;
    Student(String name, int regNo) {
        this.name = name;
        this.regNo = regNo;
    }
    Student(Student s) {
        this.name = s.name;
        this.regNo = s.regNo;
    }
    void display() {
        System.out.println("Name: " + name);
        System.out.println("Register Number: " + regNo);
    }
}
public class Main {
    public static void main(String[] args) {
        Student s1 = new Student("Sathwika", 992300800);
        Student s2 = new Student(s1);
        System.out.println("Original Student:");
        s1.display();
        System.out.println();
        System.out.println("Copied Student:");
        s2.display();
    }
} 
